{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "lib/**/*.ts",
    "mcp/**/*.ts",
    "prompts/**/*.ts",
    "cli/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "scripts"]
}
