{
  "name": "@albumi/cli",
  "version": "0.1.1",
  "description": "Albumi EAM CLI and MCP server — pull, validate, audit, and push workspace data",
  "type": "module",
  "bin": {
    "albumi": "dist/server.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node scripts/bundle-data.mjs && tsc && node -e \"require('fs').chmodSync('dist/server.js', 0o755)\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://docs.albumi.app/ai/mcp-setup/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albumi-eam/albumi-cli.git"
  },
  "bugs": {
    "url": "https://github.com/albumi-eam/albumi-cli/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "albumi",
    "eam",
    "enterprise-architecture",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "plugin",
    "cli"
  ]
}
